DISCORD_TOKEN=your_bot_token
# Optional fallback name if you prefer old naming:
# BOT_TOKEN=your_bot_token
SQLITE_DATABASE_URL=sqlite://bot_config.db?mode=rwc

# Optional binaries and cookies for yt-dlp
YT_DLP_BIN=yt-dlp
YT_COOKIE_FILE=cookies.txt

# Lavalink node (optional but recommended for music)
# Example host format: localhost:2333
LAVALINK_HOST=
LAVALINK_PASSWORD=
LAVALINK_SSL=false

# Guild config is now stored in sqlite via commands:
# /config-set and /config-show
# Important keys for temporary voice system:
# - temp_voice_category
# - temp_voice_lobby_channel
# - mod_channel
