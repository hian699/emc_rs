DISCORD_TOKEN=your_bot_token
# Optional fallback name if you prefer old naming:
# BOT_TOKEN=your_bot_token
# Optional owner IDs (comma-separated) for owner-only commands.
# If empty, bot falls back to existing role checks.
BOT_OWNER_IDS=
SQLITE_DATABASE_URL=sqlite://bot_config.db?mode=rwc

# Optional binaries and cookies for yt-dlp
YT_DLP_BIN=yt-dlp
YT_COOKIE_FILE=cookies.txt

# Lavalink node (optional but recommended for music)
# Supported host formats:
# - localhost:2333
# - ws://localhost:2333
# - wss://lavalink.example.com
# For split Dokploy deployments, set this to a Lavalink address resolvable from
# the bot container. If both apps share the same external Docker network and the
# Lavalink service has an alias like `lavalink`, use `lavalink:2333`.
# Otherwise use a reachable internal domain, public domain, or IP.
LAVALINK_HOST=
LAVALINK_PASSWORD=
LAVALINK_SSL=false

# Guild config is now stored in sqlite via commands:
# /config-set and /config-show
# Important keys for temporary voice system:
# - temp_voice_category
# - temp_voice_lobby_channel
# - mod_channel
